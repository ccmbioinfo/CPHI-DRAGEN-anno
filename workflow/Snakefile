from snakemake.utils import min_version
import pandas as pd

##### set minimum snakemake version #####
min_version("9.16.2")

def get_children_ids(ped_file):
    pedigree = pd.read_csv(ped_file, sep=None, header=None, 
                          names=["family_ID", "individual_ID", "paternal_ID", "maternal_ID", "sex", "phenotype"])
    pedigree = pedigree.astype(str)
    try:
        children = pedigree[pedigree["paternal_ID"] != "0"][pedigree["maternal_ID"] != "0"]["individual_ID"].apply(lambda x: x.split("_")[1]).values
    except IndexError:
        # non-CPHI family 
        children = pedigree[pedigree["paternal_ID"] != "0"][pedigree["maternal_ID"] != "0"]["individual_ID"].values 

    return children

family = config["run"]["family"]
samples = pd.read_table(config["run"]["samples"], dtype=str).set_index("sample", drop=False)
if config["run"]["ped"]:
    children = get_children_ids(config["run"]["ped"])
else:
    children = []

#### define file suffix if acmg_sf flag is set to true in config file ####
acmg_sf_enabled = str(config["run"].get("acmg_sf", "")).lower() == "true"
sf_suffix = ".SF" if acmg_sf_enabled else ""
slivar_preview_enabled = str(config["run"].get("slivar_preview", "")).lower() == "true"

acmg_sf_report_output = ["reports/{family}.ACMG.SF.hg38.csv".format(family=family)] if acmg_sf_enabled else []
slivar_preview_outputs = [
    "reports_slivar/{family}.wgs.coding.slivar.hg38.csv".format(family=family),
    "reports_slivar/{family}.wgs.high.impact.slivar.hg38.csv".format(family=family),
    "reports_slivar/{family}.wgs.coding.CH.hg38.csv".format(family=family),
    "reports_slivar/{family}.wgs.high.impact.CH.hg38.csv".format(family=family),
    "reports_slivar/{family}.compound.het.status.CH.hg38.csv".format(family=family),
    "reports_slivar_compare/{family}.wgs.coding.summary.tsv".format(family=family),
    "reports_slivar_compare/{family}.wgs.high.impact.summary.tsv".format(family=family),
] if slivar_preview_enabled else []
if slivar_preview_enabled and config["run"].get("hpo", ""):
    slivar_preview_outputs.extend([
        "reports_slivar/{family}.panel.slivar.hg38.csv".format(family=family),
        "reports_slivar/{family}.panel-flank.slivar.hg38.csv".format(family=family),
        "reports_slivar/{family}.panel.CH.hg38.csv".format(family=family),
        "reports_slivar/{family}.panel-flank.CH.hg38.csv".format(family=family),
        "reports_slivar_compare/{family}.panel.summary.tsv".format(family=family),
        "reports_slivar_compare/{family}.panel-flank.summary.tsv".format(family=family),
    ])
if slivar_preview_enabled and len(children) > 0:
    slivar_preview_outputs.extend([
        "reports_slivar/{family}.wgs.denovo.slivar.hg38.csv".format(family=family),
        "reports_slivar/{family}.wgs.denovo.CH.hg38.csv".format(family=family),
        "reports_slivar_compare/{family}.wgs.denovo.summary.tsv".format(family=family),
    ])

##### load rules #####
include: "rules/common.smk"
include: "rules/annotate_STRs.smk"
include: "rules/svreport.smk"
include: "rules/cnvreport.smk"
include: "rules/annotate_small_var.smk"
include: "rules/annotate_mt_var.smk"
include: "rules/qc.smk"
include: "rules/compound_hets.smk"

if str(config["run"].get("acmg_sf", "")).lower() == "true":
    include: "rules/acmg_sf.smk"

if config["run"].get("hpo",""):
    hpo_report_outputs=[
            "reports/{family}.panel.CH.hg38.csv".format(family=family),
            "reports/{family}.panel-flank.CH.hg38.csv".format(family=family),
     ]
else:
     hpo_report_outputs=[]

rule all:
    input:
        "reports/{family}.wgs.coding.CH{sf}.hg38.csv".format(family=family, sf=sf_suffix),
        "reports/{family}.wgs.high.impact.CH{sf}.hg38.csv".format(family=family, sf=sf_suffix),
        "reports/{family}.wgs.denovo.CH{sf}.hg38.csv".format(family=family, sf=sf_suffix) if len(children) > 0 else [],
        "reports/{family}.known.path.str.loci.hg38.csv".format(family=family),
        "reports/{family}.sv.CH{sf}.hg38.csv".format(family=family, sf=sf_suffix),
        "reports/{family}.cnv.CH{sf}.hg38.csv".format(family=family, sf=sf_suffix),
        "reports/{family}.mito.hg38.csv".format(family=family),
        "reports/{family}.multiqc_report.html".format(family=family),
        "reports/{family}.compound.het.status.CH.hg38.csv".format(family=family),
        *hpo_report_outputs,
        *acmg_sf_report_output,
        *slivar_preview_outputs,
